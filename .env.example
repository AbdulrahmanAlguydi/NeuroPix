# =========================================================================
# NEUROPIX ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE
# Copy this file to a new file named '.env' and fill in your actual keys.
# DO NOT commit your final '.env' file to GitHub.
# Remove the comments and fill in the values for your local development or AWS cloud production environment.
# =========================================================================

# -------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION
# -------------------------------------------------------------------------

# Choice A: Local Development Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_local_mysql_password
DB_NAME=neuropix_db
DB_PORT=3306

# Choice B: AWS Cloud Production Configuration
# DB_HOST=ask_Abdulrahman_for_the_host
# DB_USER=neuropix_dev
# DB_PASSWORD=ask_Abdulrahman_for_the_password
# DB_NAME=neuropix_db
# DB_PORT=3306

# -------------------------------------------------------------------------
# 2. AWS S3 OBJECT STORAGE CONFIGURATION
# -------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=ask_Abdulrahman_for_the_access_key_id
AWS_SECRET_ACCESS_KEY=ask_Abdulrahman_for_the_secret_access_key
AWS_BUCKET_NAME=neuropix-storage
AWS_REGION=eu-north-1